  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nBASE_PATH = r\"C:\\Users\\anany\\OneDrive\\Desktop\\CMU\\S26\\Job Apps\\KUNZ\\kunz_demo\\office\\\\\"\r\n\r\nimport os\r\nos.makedirs(BASE_PATH, exist_ok=True)\r\n\r\n# ── ROOMS ────────────────────────────────────────────────\r\nroom_collector = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_Rooms)\\\r\n    .ToElements()\r\n\r\nroom_rows = []\r\nfor r in room_collector:\r\n    try:\r\n        if r.Area == 0:\r\n            continue\r\n        name = r.get_Parameter(\r\n            BuiltInParameter.ROOM_NAME\r\n        ).AsString()\r\n        number = r.get_Parameter(\r\n            BuiltInParameter.ROOM_NUMBER\r\n        ).AsString()\r\n        area = round(r.Area * 0.092903, 2)\r\n        perimeter = round(\r\n            r.get_Parameter(\r\n                BuiltInParameter.ROOM_PERIMETER\r\n            ).AsDouble() * 0.3048, 2\r\n        )\r\n        level = doc.GetElement(r.LevelId).Name\r\n        room_rows.append(\r\n            f\"{name},{number},{area},{perimeter},{level}\"\r\n        )\r\n    except:\r\n        continue\r\n\r\nwith open(BASE_PATH + \"rooms.csv\", 'w', encoding='utf-8') as f:\r\n    f.write(\"Name,Number,Area_m2,Perimeter_m,Level\\n\")\r\n    for row in room_rows:\r\n        f.write(row + \"\\n\")\r\n\r\n# ── WALLS ────────────────────────────────────────────────\r\nwall_collector = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_Walls)\\\r\n    .ToElements()\r\n\r\nwall_rows = []\r\nfor w in wall_collector:\r\n    try:\r\n        name = w.Name\r\n        length_param = w.get_Parameter(\r\n            BuiltInParameter.CURVE_ELEM_LENGTH\r\n        )\r\n        length = round(\r\n            length_param.AsDouble() * 0.3048, 2\r\n        ) if length_param else 0\r\n        \r\n        area_param = w.get_Parameter(\r\n            BuiltInParameter.HOST_AREA_COMPUTED\r\n        )\r\n        area = round(\r\n            area_param.AsDouble() * 0.092903, 2\r\n        ) if area_param else 0\r\n        \r\n        level = doc.GetElement(w.LevelId)\r\n        level_name = level.Name if level else \"Unknown\"\r\n        \r\n        wall_rows.append(\r\n            f\"{name},{length},{area},{level_name}\"\r\n        )\r\n    except:\r\n        continue\r\n\r\nwith open(BASE_PATH + \"walls.csv\", 'w', encoding='utf-8') as f:\r\n    f.write(\"Type,Length_m,Area_m2,Level\\n\")\r\n    for row in wall_rows:\r\n        f.write(row + \"\\n\")\r\n\r\n# ── FLOORS ───────────────────────────────────────────────\r\nfloor_collector = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_Floors)\\\r\n    .ToElements()\r\n\r\nfloor_rows = []\r\nfor fl in floor_collector:\r\n    try:\r\n        name = fl.Name\r\n        area_param = fl.get_Parameter(\r\n            BuiltInParameter.HOST_AREA_COMPUTED\r\n        )\r\n        area = round(\r\n            area_param.AsDouble() * 0.092903, 2\r\n        ) if area_param else 0\r\n        \r\n        level = doc.GetElement(fl.LevelId)\r\n        level_name = level.Name if level else \"Unknown\"\r\n        \r\n        floor_rows.append(f\"{name},{area},{level_name}\")\r\n    except:\r\n        continue\r\n\r\nwith open(BASE_PATH + \"floors.csv\", 'w', encoding='utf-8') as f:\r\n    f.write(\"Type,Area_m2,Level\\n\")\r\n    for row in floor_rows:\r\n        f.write(row + \"\\n\")\r\n\r\n# ── DOORS ────────────────────────────────────────────────\r\ndoor_collector = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_Doors)\\\r\n    .ToElements()\r\n\r\ndoor_rows = []\r\nfor d in door_collector:\r\n    try:\r\n        if d.GetType().Name == \"FamilySymbol\":\r\n            continue\r\n        name = d.Name\r\n        level = doc.GetElement(d.LevelId)\r\n        level_name = level.Name if level else \"Unknown\"\r\n        door_rows.append(f\"{name},{level_name}\")\r\n    except:\r\n        continue\r\n\r\nwith open(BASE_PATH + \"doors.csv\", 'w', encoding='utf-8') as f:\r\n    f.write(\"Type,Level\\n\")\r\n    for row in door_rows:\r\n        f.write(row + \"\\n\")\r\n\r\n# ── WINDOWS ──────────────────────────────────────────────\r\nwindow_collector = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_Windows)\\\r\n    .ToElements()\r\n\r\nwindow_rows = []\r\nfor w in window_collector:\r\n    try:\r\n        if w.GetType().Name == \"FamilySymbol\":\r\n            continue\r\n        name = w.Name\r\n        level = doc.GetElement(w.LevelId)\r\n        level_name = level.Name if level else \"Unknown\"\r\n        window_rows.append(f\"{name},{level_name}\")\r\n    except:\r\n        continue\r\n\r\nwith open(BASE_PATH + \"windows.csv\", 'w', encoding='utf-8') as f:\r\n    f.write(\"Type,Level\\n\")\r\n    for row in window_rows:\r\n        f.write(row + \"\\n\")\r\n\r\nOUT = [\r\n    f\"Rooms: {len(room_rows)}\",\r\n    f\"Walls: {len(wall_rows)}\",\r\n    f\"Floors: {len(floor_rows)}\",\r\n    f\"Doors: {len(door_rows)}\",\r\n    f\"Windows: {len(window_rows)}\"\r\n]",
      "Engine": "PythonNet3",
