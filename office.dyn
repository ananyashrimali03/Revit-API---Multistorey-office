    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nBASE_PATH = r\"C:\\Users\\anany\\OneDrive\\Desktop\\CMU\\S26\\Job Apps\\KUNZ\\kunz_demo\\office\\\\\"\r\n\r\n# ── WALL MATERIAL EXTRACTION ─────────────────────────────\r\nwall_collector = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_Walls)\\\r\n    .ToElements()\r\n\r\nmaterial_rows = []\r\n\r\nfor wall in wall_collector:\r\n    try:\r\n        # Get wall area\r\n        area_param = wall.get_Parameter(\r\n            BuiltInParameter.HOST_AREA_COMPUTED\r\n        )\r\n        wall_area = area_param.AsDouble() * 0.092903 \\\r\n            if area_param else 0\r\n\r\n        if wall_area == 0:\r\n            continue\r\n\r\n        # Get level\r\n        level = doc.GetElement(wall.LevelId)\r\n        level_name = level.Name if level else \"Unknown\"\r\n\r\n        # Get wall type name\r\n        wall_type = doc.GetElement(wall.GetTypeId())\r\n        wall_type_name = wall_type.Name \\\r\n            if wall_type else \"Unknown\"\r\n\r\n        # Get compound structure layers\r\n        compound = wall_type.GetCompoundStructure()\r\n        if compound is None:\r\n            continue\r\n\r\n        layers = compound.GetLayers()\r\n        for layer in layers:\r\n            mat_id = layer.MaterialId\r\n            if mat_id == ElementId.InvalidElementId:\r\n                continue\r\n\r\n            mat = doc.GetElement(mat_id)\r\n            if not mat:\r\n                continue\r\n\r\n            # Layer thickness in meters\r\n            thickness = layer.Width * 0.3048\r\n\r\n            if thickness == 0:\r\n                continue\r\n\r\n            # Volume = wall area × layer thickness\r\n            volume = round(wall_area * thickness, 4)\r\n\r\n            material_rows.append(\r\n                f\"{mat.Name},{wall_type_name},\"\r\n                f\"{level_name},{round(wall_area,2)},\"\r\n                f\"{round(thickness,3)},{volume}\"\r\n            )\r\n\r\n    except:\r\n        continue\r\n\r\nwith open(\r\n    BASE_PATH + \"wall_materials.csv\", 'w', encoding='utf-8'\r\n) as f:\r\n    f.write(\r\n        \"Material,Wall_Type,Level,\"\r\n        \"Wall_Area_m2,Thickness_m,Volume_m3\\n\"\r\n    )\r\n    for row in material_rows:\r\n        f.write(row + \"\\n\")\r\n\r\nOUT = [\r\n    f\"Material rows extracted: {len(material_rows)}\",\r\n    \"Saved to wall_materials.csv\"\r\n]",
      "Engine": "PythonNet3",
      "VariableInputPorts": true,
